{
  "name": "nimiq-feedback",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r --filter ./backend --filter ./widget run build",
    "play": "pnpm -C widget build && pnpm -r --parallel --filter ./backend --filter ./widget run dev",
    "prepare": "rm -rf backend/.data/db/migrations && pnpm -C backend prepare",
    "dev": "pnpm -r --parallel --filter ./backend --filter ./widget run dev",
    "dev:widget": "pnpm -C widget dev:widget",
    "lint": "eslint . && pnpm -C backend lint",
    "lint:fix": "eslint . --fix && pnpm -C backend lint:fix",
    "typecheck": "pnpm -r --filter ./backend --filter ./widget run typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:lint",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "eslint-plugin-pnpm": "catalog:",
    "lint-staged": "catalog:lint",
    "simple-git-hooks": "catalog:lint",
    "typescript": "catalog:types"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
