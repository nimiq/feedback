{
  "name": "nimiq-feedback-widget",
  "type": "module",
  "version": "0.0.1-beta.5",
  "description": "Customizable feedback widget for web apps",
  "author": "Nimiq",
  "license": "MIT",
  "homepage": "https://github.com/nimiq/feedback#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimiq/feedback.git",
    "directory": "widget"
  },
  "keywords": [
    "feedback",
    "widget",
    "vue",
    "nimiq",
    "component"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/nimiq-feedback-widget.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "dist"
  ],
  "scripts": {
    "build": "pnpm build:umd",
    "build:lib": "LIB_MODE=true vite build && (test -f dist/index.d.mts && cp dist/index.d.mts dist/index.d.ts || true)",
    "build:umd": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --build --noEmit",
    "dev": "vite build --watch",
    "dev:widget": "vite dev",
    "prepublishOnly": "pnpm build:lib",
    "release": "bumpp --commit --push --tag"
  },
  "peerDependencies": {
    "reka-ui": "^2.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@iconify/utils": "catalog:unocss",
    "@rollup/plugin-replace": "catalog:bundle",
    "@tsconfig/node22": "catalog:types",
    "@types/node": "catalog:types",
    "@vitejs/plugin-vue": "catalog:bundle",
    "@vue/tsconfig": "catalog:types",
    "bumpp": "catalog:bundle",
    "nimiq-css": "catalog:unocss",
    "nimiq-icons": "catalog:",
    "reka-ui": "catalog:frontend",
    "typescript": "catalog:types",
    "unocss": "catalog:unocss",
    "unocss-preset-onmax": "catalog:unocss",
    "vite": "catalog:bundle",
    "vite-plugin-dts": "catalog:bundle",
    "vite-plugin-vue-devtools": "catalog:bundle",
    "vue": "catalog:frontend",
    "vue-tsc": "catalog:types"
  }
}
